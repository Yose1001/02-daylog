# ===== DayLog · Docker deployment env =====
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# (.env is git-ignored — never commit real secrets.)

# --- MongoDB Atlas ---
# Atlas → Connect → Drivers. Keep credentials secret.
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=daylog

# --- Auth (JWT) ---
# Generate a strong key:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Web ---
# Host port the site is published on  ->  http://<server>:<WEB_PORT>
WEB_PORT=8080

# --- CORS (optional) ---
# Not needed with the bundled nginx proxy (frontend & API share one origin).
# Set only if you serve the frontend from a different domain than the API.
CORS_ORIGINS=
